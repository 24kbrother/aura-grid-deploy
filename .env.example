# ──────────────────────────────────────────────────────────
#  Aura Grid (Shadow Smart Home) — Environment Configuration
#  Official Deploy Target: https://github.com/24kbrother/aura-grid-deploy
# ──────────────────────────────────────────────────────────

# --- Home Assistant Connection ---
# Your HA server internal URL (e.g., http://192.168.1.10:8123)
HA_URL=
# Generate a Long-lived Access Token in your HA profile
HA_TOKEN=

# --- Access Control ---
# Define a password to entry the dashboard
ACCESS_PASSWORD=123456

# --- Internal Configuration ---
# DO NOT CHANGE unless you are an advanced user
PORT=8500
NODE_ENV=production
REDIS_URL=redis://redis:6379
DATABASE_URL=file:/app/prisma/data/prod.db
